{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Streamlit App",
      "type": "python",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "app.py"
      ]
    },
    {
      "name": "Run Pipeline Script",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/pipeline.py"
    }
  ]
}